{
  "title": "Appwrite DevSecOps Dashboard",
  "uid": "appwrite-main",
  "panels": [
    {
      "title": "Pod CPU Usage",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{namespace='appwrite'}[5m])",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "title": "Pod Memory Usage",
      "type": "graph",
      "targets": [
        {
          "expr": "container_memory_usage_bytes{namespace='appwrite'}",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "title": "Pod Restarts",
      "type": "stat",
      "targets": [
        {
          "expr": "kube_pod_container_status_restarts_total{namespace='appwrite'}",
          "legendFormat": "{{pod}}"
        }
      ]
    }
  ],
  "schemaVersion": 16,
  "version": 1
}
